{
  "name": "loophaus",
  "version": "1.0.0",
  "description": "Parametric music composition kernel: score graph + instrument graph, solver, .loop DSL, synth engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "examples/loop",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run && npm run explain:check",
    "test:unit": "vitest run --exclude tests/integration/render.test.ts",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "explain:update": "tsx scripts/explain-check.ts",
    "explain:check": "tsx scripts/explain-check.ts --check",
    "intent:check": "vitest run tests/intent",
    "synth:sweep": "tsx src/demos/synth_sweep.ts",
    "loop:run": "tsx src/run_loop.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "midi-writer-js": "^3.2.1",
    "node-web-audio-api": "^2.0.0"
  }
}
